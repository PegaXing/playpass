{
  "expo": {
    "name": "PlayPass",
    "slug": "playpass",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.playpass.app",
      "deploymentTarget": "15.1"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "PlayPass needs photo access to add proof photos to missions."
        }
      ]
    ],
    "scheme": "playpass"
  }
}